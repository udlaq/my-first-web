<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>计算机小卡</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, monospace;
            background: linear-gradient(135deg, #0a0f2a 0%, #101f3f 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
        }
        .card {
            background: rgba(30, 40, 60, 0.9);
            border-radius: 48px;
            padding: 40px 24px;
            max-width: 320px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            backdrop-filter: blur(2px);
            color: #e0e0ff;
            border: 1px solid #3a4a7a;
        }
        h1 {
            font-size: 2.2em;
            color: #88ccff;
            margin-bottom: 12px;
        }
        .emoji {
            font-size: 64px;
            margin: 16px 0;
        }
        p {
            font-size: 1.2em;
            color: #ccddff;
            line-height: 1.5;
            margin: 20px 0;
        }
        button {
            background: #2a4c7a;
            border: none;
            color: white;
            font-size: 1.2em;
            padding: 12px 28px;
            border-radius: 40px;
            font-weight: bold;
            margin-top: 12px;
            cursor: pointer;
            transition: 0.2s;
        }
        button:active {
            transform: scale(0.97);
            background: #1f3e60;
        }
        footer {
            margin-top: 32px;
            font-size: 0.7em;
            color: #88aadd;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="emoji">💻⚙️</div>
        <h1>计算机小栈</h1>
        <p id="fact">计算机科学不止是敲代码</p>
        <button onclick="changeFact()">🔁 换一条知识</button>
        <footer>你的第一个计算机主题网页</footer>
    </div>

    <script>
        const facts = [
            "世界上第一个程序员是女性，叫艾达·洛夫莱斯。",
            "C语言诞生于1972年，至今仍广泛使用。",
            "CPU的硅芯片上亿个晶体管，比头发丝细几千倍。",
            "Linux 内核最初只是 Linus 的一个业余项目。",
            "HTTP 状态码 404 的由来是房间号404找不到文件。",
            "Python 名字来源于喜剧团体 Monty Python。",
            "世界上第一台通用计算机 ENIAC 重达27吨。",
            "Git 名字的意思是“蠢货”（英式俚语），Linus 自嘲。"
        ];
        function changeFact() {
            let randomIndex = Math.floor(Math.random() * facts.length);
            document.getElementById("fact").innerHTML = facts[randomIndex];
        }
    </script>
</body>
</html>